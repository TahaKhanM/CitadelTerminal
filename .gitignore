# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Replays - ignore local eval artifacts, but TRACK ranked downloads (ELO-tagged)
replays/*
!replays/.gitkeep
!replays/*_elo_*.replay
!replays/ranked/
replays/ranked/*
!replays/ranked/*.replay

# Built algo zips
algos/*.zip

# Evolution run artifacts (evolve.py outputs; see tools/evolve.py)
tools/evolve_*.json
tools/evolve_*.txt
tools/evolve_*.pkl

# Local Claude Code state
.claude/settings.local.json
.claude/projects/

# Extracted action JSONs (reproduce via tools/replay_to_actions.py)
replays/ranked/*.actions.json
tools/cfr.jar

# mypyc / C-extension build artifacts
algos/athena/build/
algos/athena/*.so
algos/athena/sim/*.so
.venv-sim/

# Generated Java/third-party build output retained only in source form.
research/finalist_repos/*/java-algo/build/

# Replay corpus (reproducible via tools/bulk_download_my_replays.py).
# By default ignore everything in Ranked Replays/ — but whitelist the Oracle
# subset we treat as a versioned backtest corpus (see docs/BACKTEST_CONTEXT.md).
Ranked Replays/*
!Ranked Replays/ORACLE_REPLAYS.md
!Ranked Replays/ORACLE_REPLAYS_MANIFEST.json
!Ranked Replays/_provenance/
!Ranked Replays/oracle_pure_upload/
!Ranked Replays/oracle_upload/
!Ranked Replays/oracle_pure_M2_upload/
!Ranked Replays/oracle_pure_M1Lite_upload/
!Ranked Replays/oracle_pure_M1Lite_IS5_upload/
!Ranked Replays/oracle_pure_M1Lite_IS6_upload/
!Ranked Replays/oracle_pure_M1Lite_VA_upload/
!Ranked Replays/oracle_pure_M1Lite_VC_upload/
!Ranked Replays/oracle_pure_M1Lite_VD_upload/
!Ranked Replays/oracle_pure_M1Lite_VF_upload/
!Ranked Replays/smart_oracle_vd_upload/
# Don't track the _source/ symlinks — they point at upload folders that
# already live elsewhere in the tree.
Ranked Replays/*/_source

# Upload folders at project root (reproducible from algos/<name>/)
/athena_baseline/
/athena_v5/
/athena_v3_diagnostic/
/athena_v3_upload/

# Engine-generated error files (per-match crash dumps; not source)
errorFile*.txt
**/errorFile*.txt
