# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*.swo

# Replays - ignore local eval artifacts, but TRACK ranked downloads (ELO-tagged)
replays/*
!replays/.gitkeep
!replays/*_elo_*.replay
!replays/ranked/
replays/ranked/*
!replays/ranked/*.replay

# Built algo zips
algos/*.zip

# Evolution run artifacts (evolve.py outputs; see tools/evolve.py)
tools/evolve_*.json
tools/evolve_*.txt
tools/evolve_*.pkl

# Local Claude Code state
.claude/settings.local.json
.claude/projects/

# Extracted action JSONs (reproduce via tools/replay_to_actions.py)
replays/ranked/*.actions.json
tools/cfr.jar

# mypyc / C-extension build artifacts
algos/athena/build/
algos/athena/*.so
algos/athena/sim/*.so
.venv-sim/

# Replay corpus (reproducible via tools/bulk_download_my_replays.py)
Ranked Replays/

# Upload folders at project root (reproducible from algos/<name>/)
/athena_baseline/
/athena_v5/
/athena_v3_diagnostic/
/athena_v3_upload/

# Engine-generated error files (per-match crash dumps; not source)
errorFile*.txt
**/errorFile*.txt
